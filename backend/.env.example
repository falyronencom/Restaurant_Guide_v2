# =====================================================
# Restaurant Guide Belarus — Backend Environment
# Copy this file to .env and fill placeholders with real values.
# Never commit .env files to Git.
# =====================================================

# -----------------------------------------------------
# Server Configuration
# -----------------------------------------------------
# Runtime mode: development | test | production
NODE_ENV=development
# HTTP port the Express server binds to
PORT=3000

# -----------------------------------------------------
# Database Configuration (PostgreSQL + PostGIS)
# -----------------------------------------------------
# Either set DATABASE_URL (Railway/Heroku style, takes precedence in scripts)
# OR set the individual DB_* variables below. Local dev uses individual vars.
DATABASE_URL=
# Hostname or IP of the PostgreSQL server
DB_HOST=localhost
# PostgreSQL listener port
DB_PORT=5432
# Database name (must include 'test' for the test environment — see tests/setup.js)
DB_NAME=restaurant_guide_belarus
# Database user
DB_USER=postgres
# Database password
DB_PASSWORD=your_db_password_here
# Connection pool tuning (config/database.js)
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2
# Idle connection timeout in milliseconds before pool reclaims a slot
DB_IDLE_TIMEOUT=10000

# -----------------------------------------------------
# Redis Configuration (rate limiting, caching)
# -----------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave empty if Redis has no password (local dev)
REDIS_PASSWORD=
# Logical database index — tests use a separate DB (typically 1) to avoid collisions
REDIS_DB=0

# -----------------------------------------------------
# JWT Configuration
# -----------------------------------------------------
# CRITICAL: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_RANDOM_32_CHAR_STRING
# Access token lifetime (short — sent on every request)
JWT_ACCESS_EXPIRY=4h
# Refresh token lifetime (long — stored in httpOnly cookie + refresh_tokens table)
JWT_REFRESH_EXPIRY=30d

# -----------------------------------------------------
# CORS Configuration
# -----------------------------------------------------
# Comma-separated list of allowed origins for browser clients
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080
CORS_CREDENTIALS=true

# -----------------------------------------------------
# Rate Limiting (Redis-backed, fails open if Redis down)
# -----------------------------------------------------
# Authenticated users: requests per window
RATE_LIMIT_AUTHENTICATED=100
# Window length in seconds for authenticated users
RATE_LIMIT_WINDOW_AUTHENTICATED=60
# Unauthenticated users: requests per window
RATE_LIMIT_UNAUTHENTICATED=300
# Window length in seconds for unauthenticated users (3600 = 1 hour)
RATE_LIMIT_WINDOW_UNAUTHENTICATED=3600

# -----------------------------------------------------
# Cloudinary (image and PDF menu hosting)
# -----------------------------------------------------
# All three are required for media uploads — see config/cloudinary.js
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# -----------------------------------------------------
# Resend (email verification, transactional email)
# -----------------------------------------------------
# API key issued in Resend dashboard (https://resend.com). Required for
# email verification flow. If unset, email sending degrades gracefully
# (logs warning, does not throw — allows local development without Resend
# setup).
# Chosen over SendGrid because SendGrid registration requires Twilio SMS
# verification, which fails for Belarus phone numbers.
RESEND_API_KEY=
# Verified sender address — must be verified in Resend (domain DNS
# authentication or Single Sender). Appears in the From header of
# verification emails. Default niriveo.by reflects planned production
# domain (purchase + DNS setup pending — Coordinator action).
EMAIL_FROM_ADDRESS=noreply@niriveo.by
# Email verification code TTL in minutes (default 15)
EMAIL_VERIFICATION_EXPIRY_MINUTES=15

# -----------------------------------------------------
# Firebase Admin SDK (push notifications via FCM)
# -----------------------------------------------------
# Provide ONE of the following (FIREBASE_SERVICE_ACCOUNT takes precedence):
#   FIREBASE_SERVICE_ACCOUNT — full service account JSON inlined as a string
#                              (recommended for Railway/Heroku, no file system needed)
#   FIREBASE_SERVICE_ACCOUNT_PATH — filesystem path to service-account.json
# If both are unset, push notifications gracefully degrade (in-app only).
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_SERVICE_ACCOUNT_PATH=

# -----------------------------------------------------
# OAuth Providers
# -----------------------------------------------------
# Google: client ID issued in Google Cloud Console for OAuth 2.0
# Used to verify ID tokens via google-auth-library (audience check).
GOOGLE_CLIENT_ID=your_google_oauth_client_id
# Yandex: no server-side credential — backend validates the token by calling
# https://login.yandex.ru/info, so no env var is needed here.

# -----------------------------------------------------
# AI Services (Smart Search + OCR menu pipeline)
# -----------------------------------------------------
# OpenRouter API key — used for both search re-ranking and OCR
OPENROUTER_API_KEY=your_openrouter_api_key
# OpenRouter base URL (override only if proxying through a custom gateway)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default chat model for Smart Search re-ranking
AI_MODEL=google/gemini-2.5-flash-lite
# Vision-capable model for OCR menu pipeline (Этап 2). Falls back to AI_MODEL if unset.
AI_OCR_MODEL=
# OCR job poller interval in milliseconds — lower = faster pickup, higher DB load
POLLER_INTERVAL_MS=10000

# -----------------------------------------------------
# Admin Bootstrap (scripts/create-admin.js only — not used at runtime)
# -----------------------------------------------------
# Run once after a fresh DB to create the first admin account:
#   node scripts/create-admin.js
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
ADMIN_NAME=Admin

# -----------------------------------------------------
# Logging (Winston)
# -----------------------------------------------------
# Levels: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=debug
# Format: json (production) | simple (dev-friendly)
LOG_FORMAT=json
