# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
tmp/
temp/
tmpclaude-*

# Log files
*.log
logs/

# Environment variables - CRITICAL
.env
.env.*
!.env.example

# EXCEPTION: .env.example should be committed as template
!**/.env.example

# Project-specific temporary files
.cache/
.temp/

# Backup files
*.bak
*~

# Flutter/Dart specific
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
*.iml
.pub-cache/
.pub/

# Seed data images (keep locally, exclude from Git)
backend/scripts/seed-images/

# Claude Code local settings (machine-specific permissions)
.claude/*.local.json

# Flutter DevTools
devtools_options.yaml

# Firebase config files (Android — contains API key)
**/google-services.json
# NOTE: GoogleService-Info.plist is tracked — it contains only public
# identifiers (CLIENT_ID, GCM_SENDER_ID) needed for Google Sign-In and
# Firebase on iOS. Google recommends committing it.

# iOS secrets (Yandex MapKit key, etc.)
**/Secrets.xcconfig
!**/Secrets.xcconfig.example

# Windows artifacts
nul

# Claude scratchpad files (temp data)
*scratchpad*.json

# Internal documentation (local only, not for public repo)
docs/

