# Backend API endpoint. Server-only (NO NEXT_PUBLIC_ prefix per D4).
# Production: set in Vercel project settings.
# Local dev: copy this file to .env.local and adjust value if running backend locally.
API_URL=https://restaurantguidev2-production.up.railway.app

# Canonical site base URL (no trailing slash). Server-only — used for
# sitemap absolute URLs, metadataBase, OG image fallback.
# Production: set to the launch domain (e.g. https://nirivio.com).
# Local dev: optional; falls back to http://localhost:3000 when unset.
SITE_URL=http://localhost:3000

# SEO Gate — single env var controlling robots/sitemap/metadata-robots layers.
# Default ON (any value except literal 'false'). Set to 'false' ONLY at the
# launch moment, after verifying SEO surface in staging.
# Flip-off path: set NOINDEX_MODE=false + SITE_URL=<launch-domain> on the
# deploy platform, then redeploy (env vars read at build time).
NOINDEX_MODE=true

# Google OAuth — Web client_id for browser Google Identity Services (GIS).
# Server-only (NO NEXT_PUBLIC_ prefix): read in the root layout and passed as a
# prop into the client AuthProvider. Use the SAME "Web application" client_id as
# the backend's GOOGLE_CLIENT_ID — the id_token `aud` must match what the
# backend verifies. Add http://localhost:3000 (dev) + the deploy origin to that
# OAuth client's Authorized JavaScript origins in Google Cloud.
# Production: set in Vercel project settings. Local dev: set in .env.local.
GOOGLE_CLIENT_ID=
